# Supabase (recommended database — PostgreSQL with built-in auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production site URL (used for auth redirects and public menu links)
NEXT_PUBLIC_SITE_URL=https://menulia.net

# OpenAI — powers one-click dish description generation in the menu builder
OPENAI_API_KEY=sk-your-openai-api-key
